# ──────────────────────────────────────────────────────────
#  Sistema de Combate a Incêndio — Variáveis de Ambiente
# ──────────────────────────────────────────────────────────
#  Copie este arquivo para .env.local e preencha os valores.
#  NUNCA commite o .env.local no repositório.
# ──────────────────────────────────────────────────────────

# Upstash Redis (banco de chaves de licença)
# Obtenha em: https://console.upstash.com/
UPSTASH_REDIS_REST_KV_REST_API_URL=https://SEU-ENDPOINT.upstash.io
UPSTASH_REDIS_REST_KV_REST_API_TOKEN=SEU_TOKEN_AQUI

# Resend (envio de e-mails de licença)
# Obtenha em: https://resend.com/api-keys
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXX

# Ativar modo de teste (redireciona e-mails para o endereço do desenvolvedor)
# Valores: "true" | "false"  (padrão: "false")
TEST_MODE=false
